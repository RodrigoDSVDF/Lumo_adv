<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Frequência Mental Poderosa</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <style>
        :root { --accent: #00d4ff; }

        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

        html, body { 
            height: 100%; 
            width: 100%; 
            overflow: hidden; 
            background-color: #010409; 
            font-family: 'Inter', sans-serif;
            color: #FFFFFF;
        }

        /* Camada do Three.js */
        #galaxy-bg {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: 1;
            pointer-events: none;
        }

        /* Estrutura Principal */
        main {
            position: relative;
            z-index: 10;
            display: flex;
            flex-direction: column;
            height: 100%;
            width: 100%;
        }

        header {
            padding: 20px 16px;
            text-align: center;
            background: rgba(1, 4, 9, 0.7);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0, 212, 255, 0.2);
        }

        .logo {
            font-size: 1.2rem;
            font-weight: 800;
            letter-spacing: 2px;
            background: linear-gradient(90deg, #fff, var(--accent));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-transform: uppercase;
        }

        /* Chat */
        #chat-container {
            flex: 1;
            overflow-y: auto;
            padding: 20px 16px;
            display: flex;
            flex-direction: column;
            gap: 15px;
            -webkit-overflow-scrolling: touch;
        }

        .message {
            max-width: 85%;
            padding: 12px 16px;
            border-radius: 20px;
            font-size: 0.95rem;
            line-height: 1.5;
            animation: msgShow 0.4s ease forwards;
        }

        .assistant {
            align-self: flex-start;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(0, 212, 255, 0.3);
            border-bottom-left-radius: 4px;
        }

        .user {
            align-self: flex-end;
            background: var(--accent);
            color: #000;
            font-weight: 600;
            border-bottom-right-radius: 4px;
        }

        /* Input Area */
        .input-area {
            padding: 15px 16px;
            padding-bottom: calc(15px + env(safe-area-inset-bottom));
            background: rgba(1, 4, 9, 0.9);
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            gap: 10px;
        }

        input {
            flex: 1;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 30px;
            padding: 12px 20px;
            color: white;
            font-size: 16px; /* Evita zoom no iOS */
            outline: none;
        }

        button {
            background: var(--accent);
            border: none;
            width: 48px;
            height: 48px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Botão Final */
        #final-cta {
            display: none;
            padding: 30px 0;
            text-align: center;
        }

        .cta-btn {
            padding: 18px 35px;
            background: #fff;
            color: #000;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 800;
            font-size: 1rem;
            box-shadow: 0 0 20px rgba(0, 212, 255, 0.5);
        }

        @keyframes msgShow {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>

<div id="galaxy-bg"></div>

<main>
    <header>
        <div class="logo">Frequência Mental Poderosa</div>
    </header>

    <div id="chat-container">
        <div id="final-cta">
            <a href="https://frequencia.nexus-manual.com.br" class="cta-btn">ELEVAR MINHA FREQUÊNCIA</a>
        </div>
    </div>

    <div class="input-area" id="input-box">
        <input type="text" id="user-input" placeholder="Sua resposta..." autocomplete="off">
        <button id="send-btn">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
        </button>
    </div>
</main>

<script>
    // --- THREE.JS ENGINE ---
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(75, window.innerWidth/window.innerHeight, 0.1, 1000);
    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    document.getElementById('galaxy-bg').appendChild(renderer.domElement);

    const geo = new THREE.BufferGeometry();
    const count = 2000;
    const pos = new Float32Array(count * 3);
    for(let i=0; i<count*3; i++) pos[i] = (Math.random() - 0.5) * 100;
    geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
    const mat = new THREE.PointsMaterial({ color: 0x00d4ff, size: 0.12, transparent: true, opacity: 0.7 });
    const stars = new THREE.Points(geo, mat);
    scene.add(stars);
    camera.position.z = 30;

    function animate() {
        requestAnimationFrame(animate);
        stars.rotation.y += 0.0005;
        renderer.render(scene, camera);
    }
    animate();

    // Ajuste de tela mobile
    window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
    });

    // --- LÓGICA DO CHAT ---
    const chat = document.getElementById('chat-container');
    const input = document.getElementById('user-input');
    const btn = document.getElementById('send-btn');
    const cta = document.getElementById('final-cta');
    const inputBox = document.getElementById('input-box');

    let stage = 0;
    let uName = "";

    async function addMsg(text, type) {
        const d = document.createElement('div');
        d.className = `message ${type}`;
        chat.insertBefore(d, cta);
        
        if(type === 'assistant') {
            let i = 0;
            while(i < text.length) {
                d.innerHTML += text.charAt(i);
                i++;
                chat.scrollTop = chat.scrollHeight;
                await new Promise(r => setTimeout(r, 15));
            }
        } else {
            d.innerText = text;
            chat.scrollTop = chat.scrollHeight;
        }
    }

    const flow = [
        () => `Incrível ter você aqui, ${uName}. Você já sentiu que sua mente opera em uma frequência abaixo do que você realmente é capaz?`,
        () => `Entendo perfeitamente. Sabia que a maioria das pessoas vive em 'modo de sobrevivência' porque nunca aprendeu a calibrar a própria energia?`,
        () => `Se você pudesse destravar hoje um comando mental para silenciar o medo e agir com clareza total, você o faria?`,
        () => `O caminho para a Frequência Mental Poderosa exige deixar o velho 'eu' para trás. Você está pronto para essa transmutação?`,
        () => `A decisão foi tomada. Estou liberando seu portal de acesso agora.`
    ];

    async function handle() {
        const val = input.value.trim();
        if(!val) return;
        input.value = "";
        await addMsg(val, 'user');

        if(stage === 0) {
            uName = val.split(" ")[0]; // Pega o primeiro nome
            stage = 1;
            await addMsg(`Bem-vindo, ${uName}. Eu sou o seu guia na Frequência Mental Poderosa.`, 'assistant');
            await new Promise(r => setTimeout(r, 800));
        }

        if(stage <= flow.length) {
            await addMsg(flow[stage-1](), 'assistant');
            stage++;
            if(stage > flow.length) {
                inputBox.style.display = 'none';
                cta.style.display = 'block';
                chat.scrollTop = chat.scrollHeight;
            }
        }
    }

    btn.onclick = handle;
    input.onkeypress = (e) => e.key === 'Enter' && handle();

    window.onload = () => addMsg("Bem-vindo ao despertar. Para começarmos a sintonizar sua nova realidade, como você se chama?", "assistant");
</script>

</body>
</html>
